# Browser (Vite) — no secrets (defaults in src/lib/appwrite.ts match Witnss on NYC Cloud)
VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=69bba04d0033f1c4e2e4

# Support / donations (public Payment Link URLs from Stripe Dashboard — not secrets)
# VITE_STRIPE_DONATION_URL=https://buy.stripe.com/...
# VITE_STRIPE_DONATION_MONTHLY_URL=https://buy.stripe.com/...
# VITE_VENMO_USERNAME=your-handle

# Netlify Functions — server only (never expose in frontend)
APPWRITE_API_KEY=
